@model PennyPincher.WebApp.Pages.Statements.IndexModel

@foreach (var s in Model.Statements)
{
    <tr>
        <td>@s.Date.ToString("yyyy-MM-dd")</td>
        <td>@s.Description</td>
        <td class="text-end @(s.Amount >= 0 ? "amount-positive" : "amount-negative")">
            @s.Amount.ToString("N2") &euro;
        </td>
        <td>@s.Account.Name</td>
        <td>@s.Category.Name</td>
        <td>
            @if (s.CheckedAt.HasValue)
            {
                <span class="checked-badge" title="@s.CheckedAt.Value.ToString("yyyy-MM-dd HH:mm")">
                    &#10003;
                </span>
            }
        </td>
    </tr>
}

@if (Model.Statements.Count == 0)
{
    <tr>
        <td colspan="6" class="text-center text-muted py-4">No statements found.</td>
    </tr>
}
