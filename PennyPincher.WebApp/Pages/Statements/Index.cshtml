@page
@model PennyPincher.WebApp.Pages.Statements.IndexModel
@{
    ViewData["Title"] = "Statements";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Statements</h4>
    <span class="text-muted small" id="statement-count">@Model.Statements.Count entries</span>
</div>

<!-- Filter bar -->
<div class="filter-bar">
    <form id="filter-form"
          hx-get="/Statements?handler=Table"
          hx-target="#statement-table-body"
          hx-trigger="change from:select, change from:input[type='date'], change from:input[type='number']"
          hx-include="#filter-form">

        <div class="row g-2 align-items-end">
            <!-- Account filter -->
            <div class="col-auto">
                <label>Account</label>
                <select class="form-select form-select-sm" name="AccountIds" multiple size="1"
                        title="All accounts">
                    @foreach (var account in Model.Accounts)
                    {
                        <option value="@account.Id"
                                selected="@(Model.AccountIds?.Contains(account.Id) == true)">
                            @account.Name
                        </option>
                    }
                </select>
            </div>

            <!-- Category filter -->
            <div class="col-auto">
                <label>Category</label>
                <select class="form-select form-select-sm" name="CategoryIds" multiple size="1"
                        title="All categories">
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category.Id"
                                selected="@(Model.CategoryIds?.Contains(category.Id) == true)">
                            @category.Name
                        </option>
                    }
                </select>
            </div>

            <!-- Date range -->
            <div class="col-auto">
                <label>From</label>
                <input type="date" class="form-control form-control-sm" name="DateFrom"
                       value="@Model.DateFrom?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-auto">
                <label>To</label>
                <input type="date" class="form-control form-control-sm" name="DateTo"
                       value="@Model.DateTo?.ToString("yyyy-MM-dd")" />
            </div>

            <!-- Amount range -->
            <div class="col-auto">
                <label>Min amt</label>
                <input type="number" class="form-control form-control-sm" name="MinAmount"
                       value="@Model.MinAmount" step="0.01" placeholder="0.00" style="width: 100px;" />
            </div>
            <div class="col-auto">
                <label>Max amt</label>
                <input type="number" class="form-control form-control-sm" name="MaxAmount"
                       value="@Model.MaxAmount" step="0.01" placeholder="0.00" style="width: 100px;" />
            </div>

            <!-- Search -->
            <div class="col-auto">
                <label>Search</label>
                <input type="text" class="form-control form-control-sm" name="SearchText"
                       value="@Model.SearchText" placeholder="Description..."
                       hx-get="/Statements?handler=Table"
                       hx-target="#statement-table-body"
                       hx-trigger="keyup changed delay:300ms"
                       hx-include="#filter-form" />
            </div>

            <!-- Sort -->
            <div class="col-auto">
                <label>Sort</label>
                <select class="form-select form-select-sm" name="SortBy">
                    <option value="date" selected="@(Model.SortBy == "date")">Date</option>
                    <option value="amount" selected="@(Model.SortBy == "amount")">Amount</option>
                </select>
            </div>
            <div class="col-auto">
                <label>Order</label>
                <select class="form-select form-select-sm" name="Direction">
                    <option value="desc" selected="@(Model.Direction == "desc")">Newest</option>
                    <option value="asc" selected="@(Model.Direction == "asc")">Oldest</option>
                </select>
            </div>

            <!-- Clear -->
            <div class="col-auto">
                <label>&nbsp;</label>
                <div>
                    <a href="/Statements" class="btn btn-outline-secondary btn-sm">Clear</a>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- Statements table -->
<div class="table-responsive">
    <table class="table table-hover table-statements">
        <thead>
            <tr>
                <th>Date</th>
                <th>Description</th>
                <th class="text-end">Amount</th>
                <th>Account</th>
                <th>Category</th>
                <th>Checked</th>
            </tr>
        </thead>
        <tbody id="statement-table-body">
            <partial name="_StatementRows" model="Model" />
        </tbody>
    </table>
</div>

<!-- Loading indicator -->
<div class="htmx-indicator text-center py-3" id="loading">
    <div class="spinner-border spinner-border-sm text-secondary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
</div>
