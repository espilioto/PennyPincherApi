@page
@model PennyPincher.WebApp.Pages.Statements.IndexModel
@{
    ViewData["Title"] = "Statements";
}

@Html.AntiForgeryToken()

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Statements</h4>
    <div class="d-flex align-items-center gap-3">
        <span class="text-muted small" id="statement-count">@Model.Statements.Count entries</span>
        <button class="btn btn-sm btn-primary" onclick="openCreateModal()">+ Add</button>
    </div>
</div>

<!-- Filter bar -->
<div class="filter-bar">
    <form id="filter-form"
          hx-get="/Statements?handler=Table"
          hx-target="#statement-table-body"
          hx-trigger="change from:select, change from:input[type='date'], change from:input[type='number'], change from:input[type='checkbox']"
          hx-include="#filter-form">

        <div class="row g-2 align-items-end">
            <!-- Account filter -->
            @{
                var selectedAccounts = Model.Accounts.Where(a => Model.AccountIds?.Contains(a.Id) == true);
                var unselectedAccounts = Model.Accounts.Where(a => Model.AccountIds?.Contains(a.Id) != true);
            }
            <div class="col-auto">
                <label>Account</label>
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                            data-bs-toggle="dropdown" data-bs-auto-close="outside">
                        @(Model.AccountIds?.Count > 0 ? $"{Model.AccountIds.Count} accounts" : "All accounts")
                    </button>
                    <div class="dropdown-menu p-2" style="max-height: 300px; overflow-y: auto;">
                        <div class="d-flex gap-1 mb-2">
                            <input type="text" class="form-control form-control-sm dropdown-search"
                                   placeholder="Search..." onclick="event.stopPropagation()" />
                            <button type="button" class="btn btn-sm btn-outline-secondary dropdown-clear"
                                    onclick="event.stopPropagation()" title="Clear">&#x2715;</button>
                        </div>
                        @foreach (var account in selectedAccounts.Concat(unselectedAccounts))
                        {
                            <div class="form-check dropdown-item-check">
                                <input class="form-check-input" type="checkbox" name="AccountIds"
                                       value="@account.Id" id="acc-@account.Id"
                                       checked="@(Model.AccountIds?.Contains(account.Id) == true)" />
                                <label class="form-check-label" for="acc-@account.Id">@account.Name</label>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Category filter -->
            @{
                var selectedCategories = Model.Categories.Where(c => Model.CategoryIds?.Contains(c.Id) == true);
                var unselectedCategories = Model.Categories.Where(c => Model.CategoryIds?.Contains(c.Id) != true);
            }
            <div class="col-auto">
                <label>Category</label>
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                            data-bs-toggle="dropdown" data-bs-auto-close="outside">
                        @(Model.CategoryIds?.Count > 0 ? $"{Model.CategoryIds.Count} categories" : "All categories")
                    </button>
                    <div class="dropdown-menu p-2" style="max-height: 300px; overflow-y: auto;">
                        <div class="d-flex gap-1 mb-2">
                            <input type="text" class="form-control form-control-sm dropdown-search"
                                   placeholder="Search..." onclick="event.stopPropagation()" />
                            <button type="button" class="btn btn-sm btn-outline-secondary dropdown-clear"
                                    onclick="event.stopPropagation()" title="Clear">&#x2715;</button>
                        </div>
                        @foreach (var category in selectedCategories.Concat(unselectedCategories))
                        {
                            <div class="form-check dropdown-item-check">
                                <input class="form-check-input" type="checkbox" name="CategoryIds"
                                       value="@category.Id" id="cat-@category.Id"
                                       checked="@(Model.CategoryIds?.Contains(category.Id) == true)" />
                                <label class="form-check-label" for="cat-@category.Id">@category.Name</label>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Date range -->
            <div class="col-auto">
                <label>From</label>
                <input type="date" class="form-control form-control-sm" name="DateFrom"
                       value="@Model.DateFrom?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-auto">
                <label>To</label>
                <input type="date" class="form-control form-control-sm" name="DateTo"
                       value="@Model.DateTo?.ToString("yyyy-MM-dd")" />
            </div>

            <!-- Amount range -->
            <div class="col-auto">
                <label>Min amt</label>
                <input type="number" class="form-control form-control-sm" name="MinAmount"
                       value="@Model.MinAmount" step="0.01" placeholder="0.00" style="width: 100px;" />
            </div>
            <div class="col-auto">
                <label>Max amt</label>
                <input type="number" class="form-control form-control-sm" name="MaxAmount"
                       value="@Model.MaxAmount" step="0.01" placeholder="0.00" style="width: 100px;" />
            </div>

            <!-- Search -->
            <div class="col-auto">
                <label>Search</label>
                <input type="text" class="form-control form-control-sm" name="SearchText"
                       value="@Model.SearchText" placeholder="Description..."
                       hx-get="/Statements?handler=Table"
                       hx-target="#statement-table-body"
                       hx-trigger="keyup changed delay:300ms"
                       hx-include="#filter-form" />
            </div>

            <!-- Sort -->
            <div class="col-auto">
                <label>Sort</label>
                <select class="form-select form-select-sm" name="SortBy">
                    <option value="date" selected="@(Model.SortBy == "date")">Date</option>
                    <option value="amount" selected="@(Model.SortBy == "amount")">Amount</option>
                </select>
            </div>
            <div class="col-auto">
                <label>Order</label>
                <select class="form-select form-select-sm" name="Direction">
                    <option value="desc" selected="@(Model.Direction == "desc")">Newest</option>
                    <option value="asc" selected="@(Model.Direction == "asc")">Oldest</option>
                </select>
            </div>

            <!-- Clear -->
            <div class="col-auto">
                <label>&nbsp;</label>
                <div>
                    <a href="/Statements" class="btn btn-outline-secondary btn-sm">Clear</a>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- Statements table -->
<div class="table-responsive">
    <table class="table table-hover table-statements">
        <thead>
            <tr>
                <th style="width: 100px;">Date</th>
                <th>Description</th>
                <th class="text-end" style="width: 110px;">Amount</th>
                <th style="width: 130px;">Account</th>
                <th style="width: 130px;">Category</th>
                <th style="width: 140px;">Checked</th>
                <th style="width: 90px;"></th>
            </tr>
        </thead>
        <tbody id="statement-table-body">
            <partial name="_StatementRows" model="Model" />
        </tbody>
    </table>
</div>

<!-- Loading indicator -->
<div class="htmx-indicator text-center py-3" id="loading">
    <div class="spinner-border spinner-border-sm text-secondary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
</div>

<!-- Statement modal -->
<div class="modal fade" id="statementModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="statementModalTitle">Add Statement</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="stmt-id" />
                <input type="hidden" id="stmt-action" />
                <div class="mb-3">
                    <label for="stmt-date" class="form-label">Date</label>
                    <input type="datetime-local" class="form-control" id="stmt-date" required />
                </div>
                <div class="mb-3">
                    <label for="stmt-amount" class="form-label">Amount</label>
                    <div class="input-group">
                        <input type="number" class="form-control" id="stmt-amount" step="0.01" required />
                        <span class="input-group-text">&euro;</span>
                    </div>
                </div>
                <div class="mb-3">
                    <label for="stmt-account" class="form-label">Account</label>
                    <select class="form-select" id="stmt-account" required>
                        @foreach (var account in Model.Accounts)
                        {
                            <option value="@account.Id">@account.Name</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label for="stmt-category" class="form-label">Category</label>
                    <select class="form-select" id="stmt-category" required>
                        @foreach (var category in Model.Categories)
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label for="stmt-description" class="form-label">Description</label>
                    <textarea class="form-control" id="stmt-description" rows="2"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveStatement()">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete confirmation modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Statement</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure?</p>
                <input type="hidden" id="delete-id" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" onclick="confirmDelete()">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var statementModal = new bootstrap.Modal(document.getElementById('statementModal'));
    var deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));

    function openCreateModal() {
        document.getElementById('statementModalTitle').textContent = 'Add Statement';
        document.getElementById('stmt-action').value = 'create';
        document.getElementById('stmt-id').value = '';
        document.getElementById('stmt-date').value = new Date().toISOString().slice(0, 16);
        document.getElementById('stmt-amount').value = '';
        document.getElementById('stmt-account').selectedIndex = 0;
        document.getElementById('stmt-category').selectedIndex = 0;
        document.getElementById('stmt-description').value = '';
        statementModal.show();
    }

    function openEditModal(id, date, amount, accountId, categoryId, description) {
        document.getElementById('statementModalTitle').textContent = 'Edit Statement';
        document.getElementById('stmt-action').value = 'edit';
        document.getElementById('stmt-id').value = id;
        document.getElementById('stmt-date').value = date;
        document.getElementById('stmt-amount').value = amount;
        document.getElementById('stmt-account').value = accountId;
        document.getElementById('stmt-category').value = categoryId;
        document.getElementById('stmt-description').value = description;
        statementModal.show();
    }

    function openDuplicateModal(date, amount, accountId, categoryId, description) {
        document.getElementById('statementModalTitle').textContent = 'Duplicate Statement';
        document.getElementById('stmt-action').value = 'create';
        document.getElementById('stmt-id').value = '';
        document.getElementById('stmt-date').value = date;
        document.getElementById('stmt-amount').value = amount;
        document.getElementById('stmt-account').value = accountId;
        document.getElementById('stmt-category').value = categoryId;
        document.getElementById('stmt-description').value = description;
        statementModal.show();
    }

    function openDeleteModal(id) {
        document.getElementById('delete-id').value = id;
        deleteModal.show();
    }

    function saveStatement() {
        var action = document.getElementById('stmt-action').value;
        var handler = action === 'edit' ? 'Edit' : 'Create';
        var body = new URLSearchParams();
        body.append('date', document.getElementById('stmt-date').value);
        body.append('amount', document.getElementById('stmt-amount').value);
        body.append('accountId', document.getElementById('stmt-account').value);
        body.append('categoryId', document.getElementById('stmt-category').value);
        body.append('description', document.getElementById('stmt-description').value);
        if (action === 'edit') {
            body.append('id', document.getElementById('stmt-id').value);
        }

        fetch('/Statements?handler=' + handler, {
            method: 'POST',
            headers: {
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            },
            body: body
        }).then(function() {
            statementModal.hide();
            window.location.reload();
        });
    }

    function confirmDelete() {
        var id = document.getElementById('delete-id').value;
        var body = new URLSearchParams();
        body.append('id', id);

        fetch('/Statements?handler=Delete', {
            method: 'POST',
            headers: {
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            },
            body: body
        }).then(function() {
            deleteModal.hide();
            window.location.reload();
        });
    }

</script>
}
