<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PennyPincher</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>(function(){var t=localStorage.getItem('pp-theme');var m={amber:['#e8b44c','232,180,76','#3a2e18','#0c0c10'],violet:['#a78bfa','167,139,250','#2a2240','#e8e8ed'],rose:['#e07a8e','224,122,142','#3a1e28','#e8e8ed'],silver:['#b0b0c0','176,176,192','#22222e','#0c0c10'],mint:['#4ade80','74,222,128','#1a2e20','#0c0c10']};var c=m[t];if(c){var s=document.documentElement.style;s.setProperty('--accent',c[0]);s.setProperty('--accent-rgb',c[1]);s.setProperty('--accent-dim',c[2]);s.setProperty('--accent-text',c[3])}})();</script>
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <nav class="sidebar d-flex flex-column p-3">
            <a class="sidebar-brand mb-4" asp-page="/Index">PennyPincher</a>

            <ul class="nav flex-column flex-grow-1">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active" : "")"
                       asp-page="/Index">Overview</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Statements") == true ? "active" : "")"
                       asp-page="/Statements/Index">Statements</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Stats/Index" ? "active" : "")"
                       asp-page="/Stats/Index">Stats</a>
                    @if (ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Stats") == true)
                    {
                        <ul class="nav flex-column ms-3">
                            <li class="nav-item">
                                <a class="nav-link nav-link-sub @(ViewContext.RouteData.Values["page"]?.ToString() == "/Stats/Monthly" ? "active" : "")"
                                   asp-page="/Stats/Monthly">Monthly</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-sub @(ViewContext.RouteData.Values["page"]?.ToString() == "/Stats/Yearly" ? "active" : "")"
                                   asp-page="/Stats/Yearly">Yearly</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-sub @(ViewContext.RouteData.Values["page"]?.ToString() == "/Stats/Savings" ? "active" : "")"
                                   asp-page="/Stats/Savings">Savings</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-sub @(ViewContext.RouteData.Values["page"]?.ToString() == "/Stats/Categories" ? "active" : "")"
                                   asp-page="/Stats/Categories">Categories</a>
                            </li>
                        </ul>
                    }
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Accounts") == true ? "active" : "")"
                       asp-page="/Accounts/Index">Accounts</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Categories") == true ? "active" : "")"
                       asp-page="/Categories/Index">Categories</a>
                </li>
            </ul>

            <div class="mt-auto">
                <a class="nav-link text-muted small @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/User") == true ? "active" : "")"
                   asp-page="/User/Index">@User.Identity?.Name</a>
                <form method="post" asp-page="/Logout">
                    <button type="submit" class="nav-link text-danger bg-transparent border-0">Logout</button>
                </form>
            </div>
        </nav>
    }

    <div class="@(User.Identity?.IsAuthenticated == true ? "main-content" : "")">
        <main class="container-fluid p-4">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/htmx/htmx.min.js"></script>
    <script src="~/lib/apexcharts/apexcharts.min.js"></script>
    <script src="~/lib/sortablejs/Sortable.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
