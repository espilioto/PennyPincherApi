@page
@model PennyPincher.WebApp.Pages.User.IndexModel
@{
    ViewData["Title"] = "Settings";
}

<h4 class="mb-4">Settings</h4>

@Html.AntiForgeryToken()

<!-- Theme -->
<div class="mb-5">
    <h6 class="text-muted mb-3">Theme</h6>
    <div class="d-flex gap-3 flex-wrap" id="settingsThemeDots"></div>
</div>

<!-- Change Password -->
<div class="mb-5" style="max-width: 400px;">
    <h6 class="text-muted mb-3">Change Password</h6>
    <div id="pwd-msg"></div>
    <div class="mb-3">
        <label for="pwd-current" class="form-label small">Current password</label>
        <input type="password" class="form-control" id="pwd-current" />
    </div>
    <div class="mb-3">
        <label for="pwd-new" class="form-label small">New password</label>
        <input type="password" class="form-control" id="pwd-new" />
    </div>
    <div class="mb-3">
        <label for="pwd-confirm" class="form-label small">Confirm new password</label>
        <input type="password" class="form-control" id="pwd-confirm" />
    </div>
    <button class="btn btn-sm btn-primary" onclick="changePassword()">Update Password</button>
</div>

@section Scripts {
<script>
    (function () {
        var container = document.getElementById('settingsThemeDots');
        if (!container || !window.ppThemes) return;

        var themes = window.ppThemes;
        var saved = localStorage.getItem('pp-theme');

        // random dot
        var rd = document.createElement('div');
        rd.className = 'settings-theme-dot';
        rd.title = 'random';
        rd.innerHTML = '<span class="settings-dot-circle" style="background:conic-gradient(#e8b44c,#a78bfa,#e07a8e,#b0b0c0,#4ade80,#e8b44c)"></span><span class="settings-dot-label">Random</span>';
        if (!saved) rd.classList.add('active');
        rd.onclick = function () {
            localStorage.removeItem('pp-theme');
            var t = themes[Math.floor(Math.random() * themes.length)];
            window.applyTheme(t);
            container.querySelectorAll('.settings-theme-dot').forEach(function (d) { d.classList.remove('active'); });
            rd.classList.add('active');
        };
        container.appendChild(rd);

        // theme dots
        themes.forEach(function (t) {
            var d = document.createElement('div');
            d.className = 'settings-theme-dot';
            d.dataset.theme = t.name;
            d.title = t.name;
            if (saved === t.name) d.classList.add('active');
            d.innerHTML = '<span class="settings-dot-circle" style="background:' + t.accent + '"></span><span class="settings-dot-label">' + t.name.charAt(0).toUpperCase() + t.name.slice(1) + '</span>';
            d.onclick = function () {
                window.applyTheme(t);
                container.querySelectorAll('.settings-theme-dot').forEach(function (el) { el.classList.toggle('active', el.dataset.theme === t.name); });
                rd.classList.remove('active');
            };
            container.appendChild(d);
        });
    })();

    function changePassword() {
        var msg = document.getElementById('pwd-msg');
        var curr = document.getElementById('pwd-current').value;
        var newPwd = document.getElementById('pwd-new').value;
        var confirm = document.getElementById('pwd-confirm').value;

        if (!curr || !newPwd) { msg.innerHTML = '<div class="alert alert-danger small py-2">All fields are required.</div>'; return; }
        if (newPwd !== confirm) { msg.innerHTML = '<div class="alert alert-danger small py-2">Passwords do not match.</div>'; return; }

        fetch('/User?handler=ChangePassword', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            },
            body: JSON.stringify({ currentPassword: curr, newPassword: newPwd })
        }).then(function (r) {
            if (r.ok) {
                msg.innerHTML = '<div class="alert alert-success small py-2">Password updated.</div>';
                document.getElementById('pwd-current').value = '';
                document.getElementById('pwd-new').value = '';
                document.getElementById('pwd-confirm').value = '';
            } else {
                r.json().then(function (d) {
                    var text = 'Password change failed.';
                    if (Array.isArray(d)) text = d.map(function (e) { return e.description; }).join(' ');
                    else if (d.message) text = d.message;
                    msg.innerHTML = '<div class="alert alert-danger small py-2">' + text + '</div>';
                }).catch(function () {
                    msg.innerHTML = '<div class="alert alert-danger small py-2">Password change failed.</div>';
                });
            }
        });
    }
</script>
}
