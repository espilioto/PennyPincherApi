@page
@model PennyPincher.WebApp.Pages.Categories.IndexModel
@{
    ViewData["Title"] = "Categories";
}

@Html.AntiForgeryToken()

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Categories</h4>
    <div class="d-flex align-items-center gap-3">
        <span class="text-muted small">@Model.Categories.Count categories</span>
        <button class="btn btn-sm btn-primary" onclick="openCreateModal()">+ Add</button>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-hover table-statements">
        <thead>
            <tr>
                <th>Name</th>
                <th style="width: 90px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model.Categories)
            {
                var nameEscaped = c.Name.Replace("'", "\\'").Replace("\"", "&quot;");
                <tr>
                    <td>@c.Name</td>
                    <td class="text-nowrap">
                        <button class="btn btn-sm btn-link p-0 me-1" title="Edit"
                                onclick="openEditModal(@c.Id, '@nameEscaped')">
                            &#9998;
                        </button>
                        <button class="btn btn-sm btn-link p-0 text-danger" title="Delete"
                                onclick="openDeleteModal(@c.Id)">
                            &#10005;
                        </button>
                    </td>
                </tr>
            }
            @if (Model.Categories.Count == 0)
            {
                <tr>
                    <td colspan="2" class="text-center text-muted py-4">No categories found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Category modal -->
<div class="modal fade" id="categoryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="categoryModalTitle">Add Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="cat-id" />
                <input type="hidden" id="cat-action" />
                <div class="mb-3">
                    <label for="cat-name" class="form-label">Name</label>
                    <input type="text" class="form-control" id="cat-name" required />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveCategory()">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete confirmation modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure?</p>
                <input type="hidden" id="delete-id" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" onclick="confirmDelete()">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var categoryModal = new bootstrap.Modal(document.getElementById('categoryModal'));
    var deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));

    function openCreateModal() {
        document.getElementById('categoryModalTitle').textContent = 'Add Category';
        document.getElementById('cat-action').value = 'create';
        document.getElementById('cat-id').value = '';
        document.getElementById('cat-name').value = '';
        categoryModal.show();
    }

    function openEditModal(id, name) {
        document.getElementById('categoryModalTitle').textContent = 'Edit Category';
        document.getElementById('cat-action').value = 'edit';
        document.getElementById('cat-id').value = id;
        document.getElementById('cat-name').value = name;
        categoryModal.show();
    }

    function openDeleteModal(id) {
        document.getElementById('delete-id').value = id;
        deleteModal.show();
    }

    function saveCategory() {
        var action = document.getElementById('cat-action').value;
        var handler = action === 'edit' ? 'Edit' : 'Create';
        var body = new URLSearchParams();
        body.append('name', document.getElementById('cat-name').value);
        if (action === 'edit') {
            body.append('id', document.getElementById('cat-id').value);
        }

        fetch('/Categories?handler=' + handler, {
            method: 'POST',
            headers: {
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            },
            body: body
        }).then(function(r) {
            if (!r.ok) { alert('Operation failed.'); return; }
            categoryModal.hide();
            window.location.reload();
        });
    }

    function confirmDelete() {
        var id = document.getElementById('delete-id').value;
        var body = new URLSearchParams();
        body.append('id', id);

        fetch('/Categories?handler=Delete', {
            method: 'POST',
            headers: {
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            },
            body: body
        }).then(function(r) {
            if (!r.ok) { alert('Delete failed.'); return; }
            deleteModal.hide();
            window.location.reload();
        });
    }
</script>
}
