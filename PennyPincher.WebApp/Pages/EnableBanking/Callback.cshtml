@page
@model PennyPincher.WebApp.Pages.EnableBanking.CallbackModel
@{
    ViewData["Title"] = "Enable Banking callback";
}

<h4>Enable Banking callback</h4>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
    <a class="btn btn-secondary btn-sm" asp-page="/EnableBanking/Sandbox">Back to sandbox</a>
}
else if (Model.Session is not null)
{
    <div class="alert alert-success">
        Session established. @Model.Session.Accounts.Count account(s) linked, valid until @Model.Session.ValidUntil.ToString("u").
    </div>
    <a class="btn btn-primary btn-sm" asp-page="/EnableBanking/Sandbox">Continue to sandbox</a>
}
else
{
    <p class="text-muted">Completing session...</p>
}
